; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Out_Of_Place"
config/tags=PackedStringArray("discojam")
run/main_scene="uid://c6sk8p3wsqtx0"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Global="*uid://dno0dodlysjdo"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"Bob": "res://Dialogue_/Characters/Bob.dch",
"Nate": "res://Dialogue_/Characters/Nate.dch",
"Player_ch": "res://Dialogue_/Characters/Player_ch.dch",
"Sadie": "res://Dialogue_/Characters/Sadie.dch",
"Zen_Bob_Sadie_Nate": "res://Dialogue_/Characters/Zen_Bob_Sadie_Nate.dch",
"Zen_ch": "res://Dialogue_/Characters/Zen_ch.dch",
"unit_test_character": "res://Tests/Resources/unit_test_character.dch"
}
directories/dtl_directory={
"Bob_advises_Player_of_Sadie": "res://Dialogue_/Timelines/Bob_advises_Player_of_Sadie.dtl",
"Bob_and_Player_intro_convo": "res://Dialogue_/Timelines/Bob_and_Player_intro_convo.dtl",
"Bob_apologizes_to_Player": "res://Dialogue_/Timelines/Bob_apologizes_to_Player.dtl",
"Everyone_and_choice": "res://Dialogue_/Timelines/Everyone_and_choice.dtl",
"Player_finds_lamp_for_Nate": "res://Dialogue_/Timelines/Player_finds_lamp_for_Nate.dtl",
"Player_found_Sadies_tissues": "res://Dialogue_/Timelines/Player_found_Sadies_tissues.dtl",
"Player_intro_Nate": "res://Dialogue_/Timelines/Player_intro_Nate.dtl",
"Player_offers_to_help_Sadie": "res://Dialogue_/Timelines/Player_offers_to_help_Sadie.dtl",
"Sadies_advises_Player_of_Nate": "res://Dialogue_/Timelines/Sadies_advises_Player_of_Nate.dtl",
"Sadies_gets_tissues_thanks_Player": "res://Dialogue_/Timelines/Sadies_gets_tissues_thanks_Player.dtl",
"Zen_advises_Bob_to_Player": "res://Dialogue_/Timelines/Zen_advises_Bob_to_Player.dtl",
"Zen_and_Player_intro_convo": "res://Dialogue_/Timelines/Zen_and_Player_intro_convo.dtl"
}
layout/style_directory={}
layout/style_list=[]
layout/default_style="Default"
glossary/default_case_sensitive=true

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "pink",
"res://Dialogue_/": "yellow",
"res://Music/": "purple",
"res://Scenes/": "blue",
"res://Scripts/": "gray",
"res://addons/": "orange"
}

[global_group]

note=""
player=""

